APP_TITLE=RAG Chatbot API
APP_DESCRIPTION=API for asking questions across contracts, research papers, and notes.
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
RATE_LIMIT=10/minute
API_MEMORY_TURNS=3
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
REDIS_URL=redis://localhost:6379/0

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_chatbot

DOCS_DIR=docs
VECTORSTORE_DIR=vectorstore

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507
LLM_MAX_NEW_TOKENS=600

CHUNK_SIZE=400
CHUNK_OVERLAP=50

RETRIEVAL_K=12
RETRIEVAL_FETCH_K=20
RERANK_TOP_N=3

ALLOW_DANGEROUS_DESERIALIZATION=true
